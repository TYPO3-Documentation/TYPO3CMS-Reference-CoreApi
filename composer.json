{
    "name": "typo3/reference-coreapi",
    "description": "Main TYPO3 Core documentation",
    "license": "OPL-1.0",
    "type": "typo3-cms-documentation",
    "require": {
        "php": ">=8.2",
        "typo3/cms-core": "^14.3"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "~2.51.0",
        "friendsofphp/php-cs-fixer": "^3.46",
        "garvinhicking/clinspector-gadget": "^0.1.1",
        "symfony/yaml": "^7.0",
        "t3docs/blog-example": "dev-main",
        "t3docs/codesnippet": "dev-main",
        "t3docs/examples": "^14.1",
        "t3docs/site-package": "dev-main",
        "typo3/cms-adminpanel": "^14.3",
        "typo3/cms-backend": "^14.3",
        "typo3/cms-belog": "^14.3",
        "typo3/cms-beuser": "^14.3",
        "typo3/cms-dashboard": "^14.3",
        "typo3/cms-extbase": "^14.3",
        "typo3/cms-extensionmanager": "^14.3",
        "typo3/cms-felogin": "^14.3",
        "typo3/cms-filelist": "^14.3",
        "typo3/cms-filemetadata": "^14.3",
        "typo3/cms-fluid": "^14.3",
        "typo3/cms-fluid-styled-content": "^14.3",
        "typo3/cms-form": "^14.3",
        "typo3/cms-frontend": "^14.3",
        "typo3/cms-impexp": "^14.3",
        "typo3/cms-indexed-search": "^14.3",
        "typo3/cms-info": "^14.3",
        "typo3/cms-install": "^14.3",
        "typo3/cms-linkvalidator": "^14.3",
        "typo3/cms-lowlevel": "^14.3",
        "typo3/cms-opendocs": "^14.3",
        "typo3/cms-recycler": "^14.3",
        "typo3/cms-redirects": "^14.3",
        "typo3/cms-reports": "^14.3",
        "typo3/cms-rte-ckeditor": "^14.3",
        "typo3/cms-scheduler": "^14.3",
        "typo3/cms-seo": "^14.3",
        "typo3/cms-setup": "^14.3",
        "typo3/cms-styleguide": "^14.3",
        "typo3/cms-sys-note": "^14.3",
        "typo3/cms-tstemplate": "^14.3",
        "typo3/cms-viewpage": "^14.3",
        "typo3/cms-workspaces": "^14.3",
        "typo3/testing-framework": "^9"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        },
        "bin-dir": ".Build/bin",
        "sort-packages": true,
        "vendor-dir": ".Build/vendor"
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "t3docs-reference-coreapi",
            "web-dir": ".Build/web"
        }
    }
}
